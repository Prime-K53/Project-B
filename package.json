{
  "name": "prime-erp-workspace",
  "private": true,
  "version": "1.0.0",
  "main": "src/index.js",
  "description": "Prime ERP System - Enterprise Resource Management",
  "scripts": {
    "backend:install": "npm --prefix backend install",
    "frontend:install": "npm --prefix frontend install",
    "install-all": "npm run frontend:install && npm run backend:install",
    "postinstall": "node scripts/postinstall.cjs",
    "backend:dev": "npm --prefix backend run dev",
    "frontend:dev": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build": "npm run frontend:install && npm --prefix frontend run build",
    "start": "node src/index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4",
    "sqlite3": "^6.0.1",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  }
}
